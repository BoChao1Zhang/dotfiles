model_provider = "ai"
model = "gpt-5.5"
model_reasoning_effort = "xhigh"
disable_response_storage = true
service_tier = "fast"
approvals_reviewer = "user"
approval_policy = "never"

model_context_window = 4000000
model_auto_compact_token_limit = 360000
personality = "friendly"
sandbox_mode = "danger-full-access"
  
[model_providers.ai]
name = "ai"
wire_api = "responses"
requires_openai_auth = true
base_url = "https://dmit.bcncp.org/v1"

[mcp_servers]

[mcp_servers.ankimcp]
type = "stdio"
command = "npx"
args = ["-y", "@ankimcp/anki-mcp-server", "--stdio"]

[mcp_servers.siyuan-sisyphus]
type = "http"
url = "http://127.0.0.1:36806/mcp"
headers = { Authorization = "Bearer {{ env "SIYUAN_SISYPHUS_TOKEN" }}" }

[mcp_servers.siyuan-sisyphus.http_headers]
Authorization = "Bearer {{ env "SIYUAN_SISYPHUS_TOKEN" }}"

[mcp_servers.Grok-search]
type = "stdio"
command = "uvx"
args = ["--from", "git+https://github.com/GuDaStudio/GrokSearch@grok-with-tavily", "grok-search"]

[mcp_servers.Grok-search.env]
GROK_API_KEY = "{{ env "GROK_API_KEY" }}"
GROK_API_URL = "https://api.x.ai/v1"
TAVILY_API_KEY = "{{ env "TAVILY_API_KEY" }}"
TAVILY_API_URL = "https://api.tavily.com"

