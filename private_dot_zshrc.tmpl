# User configuration sourced by interactive shells.

# -----------------
# Zsh configuration
# -----------------

#
# History
#

HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000

setopt APPEND_HISTORY
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_DUPS
setopt HIST_REDUCE_BLANKS
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY

#
# Input/output
#

bindkey -e

# Remove path separator from WORDCHARS so e.g. ^W deletes one path segment.
WORDCHARS=${WORDCHARS//[\/]}

setopt AUTO_CD

#
# User-local toolchain
#

[ ! -f "$HOME/.config/dotfiles/shell-env.sh" ] || . "$HOME/.config/dotfiles/shell-env.sh"

_dotfiles_prepend_fpath_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || return
  fpath=("$dir" ${fpath:#"$dir"})
}

for _dotfiles_zsh_prefix in \
  "${DOTFILES_TOOL_PREFIX:-}" \
  "${CONDA_PREFIX:-}" \
  "$HOME/.local/share/dotfiles/toolchain"; do
  [[ -n "$_dotfiles_zsh_prefix" ]] || continue
  _dotfiles_prepend_fpath_dir "$_dotfiles_zsh_prefix/share/zsh/site-functions"
  _dotfiles_prepend_fpath_dir "$_dotfiles_zsh_prefix/share/zsh/functions"
  _dotfiles_prepend_fpath_dir "$_dotfiles_zsh_prefix/share/zsh/$ZSH_VERSION/functions"
  for _dotfiles_zsh_dir in \
    "$_dotfiles_zsh_prefix"/share/zsh/functions/*(N-/) \
    "$_dotfiles_zsh_prefix"/share/zsh/$ZSH_VERSION/functions/*(N-/) \
    "$_dotfiles_zsh_prefix"/share/zsh/*/functions(N-/) \
    "$_dotfiles_zsh_prefix"/share/zsh/*/functions/*(N-/); do
    _dotfiles_prepend_fpath_dir "$_dotfiles_zsh_dir"
  done
done
unset _dotfiles_zsh_prefix _dotfiles_zsh_dir

# --------------------
# Module configuration
# --------------------

# zsh-autosuggestions: skip per-precmd widget rebind (safe because
# zsh-autosuggestions is the last module loaded in ~/.zimrc).
ZSH_AUTOSUGGEST_MANUAL_REBIND=1

# zsh-syntax-highlighting: enable main + brackets highlighters.
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets)

# Completion behavior (case-insensitive, menu select).
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' menu select

# ------------------
# Initialize modules
# ------------------

ZIM_HOME=${ZDOTDIR:-${HOME}}/.zim

_dotfiles_repair_zsh_compinit_permissions() {
  local dir
  for dir in "$HOME" "$ZIM_HOME" "${DOTFILES_TOOL_PREFIX:-}/share/zsh"; do
    [[ -d "$dir" ]] || continue
    if [[ "$dir" == "$HOME" ]]; then
      command chmod go-w "$dir" 2>/dev/null || true
    else
      command chmod -R go-w "$dir" 2>/dev/null || true
    fi
  done
}

# Download zimfw plugin manager if missing.
if [[ ! -e ${ZIM_HOME}/zimfw.zsh ]]; then
  if (( ${+commands[curl]} )); then
    curl -fsSL --create-dirs -o ${ZIM_HOME}/zimfw.zsh \
        https://github.com/zimfw/zimfw/releases/latest/download/zimfw.zsh || true
  elif (( ${+commands[wget]} )); then
    mkdir -p ${ZIM_HOME} && wget -nv -O ${ZIM_HOME}/zimfw.zsh \
        https://github.com/zimfw/zimfw/releases/latest/download/zimfw.zsh || true
  fi
fi
# Install missing modules, and update ${ZIM_HOME}/init.zsh if missing or outdated.
if [[ -r ${ZIM_HOME}/zimfw.zsh && ! ${ZIM_HOME}/init.zsh -nt ${ZIM_CONFIG_FILE:-${ZDOTDIR:-${HOME}}/.zimrc} ]]; then
  source ${ZIM_HOME}/zimfw.zsh init || true
fi
_dotfiles_repair_zsh_compinit_permissions
# Initialize modules.
[[ ! -r ${ZIM_HOME}/init.zsh ]] || source ${ZIM_HOME}/init.zsh

# ------------------
# Post-init bindings
# ------------------

# history-substring-search widget bindings (must come after zimfw init).
if zle -l | command grep -qx 'history-substring-search-up'; then
  bindkey "${terminfo[kcuu1]}" history-substring-search-up
  bindkey "${terminfo[kcud1]}" history-substring-search-down
  bindkey '^[[A' history-substring-search-up
  bindkey '^[[B' history-substring-search-down
  bindkey '^P' history-substring-search-up
  bindkey '^N' history-substring-search-down
fi

# ------------------
# Environment / tools
# ------------------

export SHELL="/bin/zsh"

export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git" 2>/dev/null'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
if [[ -n "${BASH_VERSION:-}" && -s "$NVM_DIR/bash_completion" ]]; then
  . "$NVM_DIR/bash_completion"
fi

if (( ${+commands[zoxide]} )); then
  eval "$(zoxide init zsh)"
fi

if (( ${+commands[starship]} )); then
  eval "$(starship init zsh)"
fi

# ------------------
# User helpers
# ------------------

# yazi: cd into directory chosen on exit.
function yy() {
  local tmp cwd
  if ! command -v yazi >/dev/null 2>&1; then
    printf 'yazi is not installed.\n' >&2
    return 127
  fi
  tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi --cwd-file="$tmp" "$@"
  if [ -f "$tmp" ]; then
    cwd="$(command cat -- "$tmp")"
    if [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
      builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
  fi
}

alias lzg='lazygit'
alias btm='btop'
alias mdp='glow -p'
alias cc-h3c='nohup xpra attach ssh://bc@h3c/100 >/tmp/xpra-h3c.log 2>&1 &!'

proxy_on() {
  export http_proxy="http://127.0.0.1:7897"
  export https_proxy="http://127.0.0.1:7897"
  export HTTP_PROXY="$http_proxy"
  export HTTPS_PROXY="$https_proxy"
  export all_proxy="socks5://127.0.0.1:7897"
  export ALL_PROXY="$all_proxy"
  export no_proxy="localhost,127.0.0.1,::1"
  export NO_PROXY="$no_proxy"
}

proxy_off() {
  unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY
  unset all_proxy ALL_PROXY no_proxy NO_PROXY
}

if [[ "${DOTFILES_AUTO_PROXY:-0}" == "1" ]]; then
  proxy_on
fi

[ ! -f ~/.config/tmux/scripts/tmux_aliases.sh ] || source ~/.config/tmux/scripts/tmux_aliases.sh

[ ! -f "$HOME/.local/bin/env" ] || . "$HOME/.local/bin/env"

# Hermes Agent — ensure ~/.local/bin is on PATH
export PATH="$HOME/.local/bin:$PATH"

# Private workflow tokens. This file is generated by scripts/secrets-install.sh.
[ ! -f "$HOME/.config/dotfiles/secrets.env" ] || source "$HOME/.config/dotfiles/secrets.env"
if [[ "$OSTYPE" == darwin* ]]; then
  export PATH="/Applications/Xpra.app/Contents/MacOS:$PATH"
fi

# lazyssh: strip proxy env. ALL_PROXY is the real culprit (Go's proxy.FromEnvironment
# routes SSH dials through SOCKS5); HTTP(S)_PROXY stripped defensively for any HTTP calls.
lazyssh() {
  env -u ALL_PROXY -u all_proxy -u HTTP_PROXY -u http_proxy -u HTTPS_PROXY -u https_proxy command lazyssh "$@"
}

_dotfiles_repo() {
  local repo
  for repo in \
    "${DOTFILES_REPO:-}" \
    "$HOME/dotfiles" \
    "$HOME/.local/share/chezmoi" \
    "/Users/macbook/Documents/Codex/2026-05-09/create-dotfile-chezmoi-codex-claude-tmux/dotfiles"; do
    if [ -n "$repo" ] && [ -d "$repo/.git" ] && [ -x "$repo/scripts/bootstrap.sh" ]; then
      printf '%s\n' "$repo"
      return 0
    fi
  done
  printf 'dotfiles repo not found. Set DOTFILES_REPO=/path/to/dotfiles.\n' >&2
  return 1
}

_dotfiles_git_preflight() {
  if ! git config user.name >/dev/null 2>&1 || ! git config user.email >/dev/null 2>&1; then
    cat >&2 <<'EOF'
Git identity is not configured yet.

Run once on this machine:
  git config --global user.name "BoChao1Zhang"
  git config --global user.email "3210191548@qq.com"

EOF
    return 1
  fi

  local remote_url
  remote_url="$(git remote get-url origin 2>/dev/null || true)"
  case "$remote_url" in
    https://github.com/*)
      cat >&2 <<'EOF'
GitHub no longer accepts account passwords for git push.

Use SSH for this repo:
  ./scripts/setup-github-ssh.sh

Then add the printed public key to GitHub SSH keys and rerun dotup.

EOF
      return 1
      ;;
  esac
}

dotup() {
  local repo msg capture_tokens=0
  repo="$(_dotfiles_repo)" || return
  if [ "${1:-}" = "--tokens" ]; then
    capture_tokens=1
    shift
  fi
  msg="${1:-Update dotfiles from $(hostname -s 2>/dev/null || hostname)}"

  (
    cd "$repo" || exit 1
    _dotfiles_git_preflight || exit 1
    if [ "$capture_tokens" = 1 ]; then
      ./scripts/secrets-capture.sh
    fi
    ./scripts/refresh-from-home.sh
    ./scripts/scan-secrets.sh
    git add -A
    if git diff --cached --quiet; then
      printf 'No dotfiles changes to upload.\n'
      exit 0
    fi
    git commit -m "$msg"
    git push
  )
}

dotdown() {
  local repo
  repo="$(_dotfiles_repo)" || return

  (
    cd "$repo" || exit 1
    git pull --ff-only
    if [ -f secrets/secrets.env.age ]; then
      ./scripts/secrets-install.sh
    fi
    ./scripts/bootstrap.sh
    chezmoi --source "$repo" apply
  )
}
